{
  "title": "Global FX Intelligence Terminal",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-5y",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "currency",
        "type": "query",
        "datasource": "MySQL",
        "refresh": 1,
        "includeAll": true,
        "query": "SELECT DISTINCT currency_code FROM global_exchange_rates ORDER BY currency_code"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT currency_code) FROM global_exchange_rates"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "USD Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='USD' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "EUR Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='EUR' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "JPY Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='JPY' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Average FX Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT AVG(rate) FROM global_exchange_rates"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "BOT Currency Count",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) FROM bot_exchange_rates"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Top 10 Strongest Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT currency_code as metric, rate FROM global_exchange_rates ORDER BY rate DESC LIMIT 10"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Top 10 Weakest Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT currency_code as metric, rate FROM global_exchange_rates ORDER BY rate ASC LIMIT 10"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Currency Trend Explorer",
      "datasource": "MySQL",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT rate_date as time, rate FROM global_exchange_rates WHERE currency_code='$currency' ORDER BY rate_date"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "FX Volatility Proxy",
      "datasource": "MySQL",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "\nSELECT rate_date as time, ABS(rate - LAG(rate) OVER (ORDER BY rate_date)) as value\nFROM global_exchange_rates\nWHERE currency_code='$currency'\n"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "FX Moving Average",
      "datasource": "MySQL",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "\nSELECT rate_date as time,\nAVG(rate) OVER (ORDER BY rate_date ROWS BETWEEN 30 PRECEDING AND CURRENT ROW) as value\nFROM global_exchange_rates\nWHERE currency_code='$currency'\n"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "BOT Buy/Sell Spread",
      "datasource": "MySQL",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT updated_at as time, (selling_rate-buying_rate) as value FROM bot_exchange_rates ORDER BY updated_at"
        }
      ]
    },
