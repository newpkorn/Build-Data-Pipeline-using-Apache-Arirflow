{
  "title": "Ultimate FX Portfolio Killer Dashboard",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-5y",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "currency",
        "type": "query",
        "datasource": "MySQL",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "query": "SELECT DISTINCT currency_code FROM global_exchange_rates ORDER BY currency_code"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total FX Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT currency_code) FROM global_exchange_rates"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "USD Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='USD' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "EUR Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='EUR' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GBP Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT rate FROM global_exchange_rates WHERE currency_code='GBP' ORDER BY rate_date DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Average FX Rate",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT AVG(rate) FROM global_exchange_rates"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "BOT Currency Count",
      "datasource": "MySQL",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) FROM bot_exchange_rates"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Top 10 Strongest Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT currency_code as metric, rate FROM global_exchange_rates ORDER BY rate DESC LIMIT 10"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Top 10 Weakest Currencies",
      "datasource": "MySQL",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT currency_code as metric, rate FROM global_exchange_rates ORDER BY rate ASC LIMIT 10"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Currency Trend Explorer",
      "datasource": "MySQL",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT rate_date as time, rate FROM global_exchange_rates WHERE currency_code='$currency' ORDER BY rate_date"
