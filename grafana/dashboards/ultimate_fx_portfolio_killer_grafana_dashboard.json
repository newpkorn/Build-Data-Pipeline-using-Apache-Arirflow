          "rawSql": "SELECT updated_at as time, selling_rate as value FROM bot_exchange_rates ORDER BY updated_at"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "BOT Official FX Table",
      "datasource": "MySQL",
      "gridPos": {
