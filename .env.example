# ==========================================================

# Data Pipeline Environment Configuration

# Copy this file to `.env` and update values as needed.

# ==========================================================

# ==========================================================

# PostgreSQL (Airflow Metadata Database)

# ==========================================================

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ==========================================================

# MySQL (Source Database for ETL)

# ==========================================================

MYSQL_ROOT_PASSWORD=root
MYSQL_USER=airflow
MYSQL_PASSWORD=airflow
MYSQL_DB=airflow

# ==========================================================

# Airflow Admin User

# Created during container initialization

# ==========================================================

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=[admin@example.com](mailto:admin@example.com)

# ==========================================================

# Airflow Core Configuration

# ==========================================================

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__PARALLELISM=8
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=2
AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT=False

# ==========================================================

# Airflow Webserver (optional if using reverse proxy)

# Example:

# https://your-domain.com/airflow

# ==========================================================

# AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080

# ==========================================================

# Grafana Monitoring

# ==========================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SERVER_ROOT_URL=http://localhost:3000

# ==========================================================

# CSV ETL Pipeline Configuration

# ==========================================================

CSV_FILE_PATH=/opt/airflow/data/sample.csv
TABLE_NAME=csv_import_table

# ==========================================================

# Bot Configuration

# ==========================================================

BOT_API_KEY=your_bot_api_key_here

# ==========================================================

# Alerting Configuration

# Discord webhook for pipeline notifications

# ==========================================================

DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url

# ==========================================================

# Weather Pipeline Configuration

# ==========================================================

OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_CITIES=
WEATHER_ALERT_EMAIL=weather-alerts@example.com
